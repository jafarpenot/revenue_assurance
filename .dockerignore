# Secrets and local state — passed at run-time via --env-file instead.
.env
.env.local

# VCS, IDE, OS noise
.git/
.gitignore
.vscode/
.idea/
.claude/
.DS_Store

# Python virtualenvs and caches
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# data/ is intentionally NOT ignored — the Dockerfile COPYs it into the image.

# Logs (regenerated at runtime)
agent_trace.log
*.log

# Docs / brief — not needed in the image
*.md
